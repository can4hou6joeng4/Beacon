# Cloud deployment configuration sketch.
# Copy values into the actual deployment provider's secret/config system.
# Do not commit real secrets.

# One-time/admin bootstrap auth.
# Set as a deployment secret, not a plain variable.
AUTH_BOOTSTRAP_TOKEN=replace-with-long-random-token

# Cloud mode selector.
AUDIT_RUNTIME_MODE=paddleocr
NEXT_PUBLIC_AUDIT_RUNTIME_MODE=paddleocr

# Cloudflare Workers database binding.
# In wrangler.jsonc this is bound as AUDIT_DB. Use D1 migrations under web/migrations.
AUDIT_DB_DRIVER=d1

# Object storage for PDFs and generated artifacts.
# Cloudflare Workers keep the native R2 binding for server-side artifact
# reads/writes. Large PDF uploads automatically use direct browser-to-R2
# presigned PUT URLs when the S3 signing config below is present.
AUDIT_OBJECT_STORE_DRIVER=r2-binding
AUDIT_OBJECT_PREFIX=jobs

# R2 S3-compatible signing config. Set the access key and secret as deployment
# secrets, not plain variables.
AUDIT_OBJECT_STORE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
AUDIT_OBJECT_BUCKET=pdf-audit-artifacts
AUDIT_OBJECT_REGION=auto
AUDIT_OBJECT_ACCESS_KEY_ID=<secret>
AUDIT_OBJECT_SECRET_ACCESS_KEY=<secret>
AUDIT_OBJECT_UPLOAD_EXPIRES_SECONDS=900
AUDIT_OBJECT_DOWNLOAD_EXPIRES_SECONDS=3600

# OCR provider adapter.
AUDIT_OCR_PROVIDER=paddleocr
PADDLEOCR_API_BASE_URL=https://paddleocr.aistudio-app.com/api/v2/ocr
PADDLEOCR_API_TOKEN=
PADDLEOCR_MODEL=PaddleOCR-VL-1.5
PADDLEOCR_POLL_INTERVAL_MS=5000

# PaddleOCR optional payload defaults.
PADDLEOCR_USE_DOC_ORIENTATION_CLASSIFY=false
PADDLEOCR_USE_DOC_UNWARPING=false
PADDLEOCR_USE_CHART_RECOGNITION=false

# Alternative provider placeholders.
AWS_TEXTRACT_REGION=
AWS_TEXTRACT_ROLE_ARN=
AWS_TEXTRACT_SNS_TOPIC_ARN=
AWS_TEXTRACT_SQS_QUEUE_URL=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
